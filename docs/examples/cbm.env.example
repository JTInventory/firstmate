# Optional local First Mate CBM settings (copy to config/cbm.env — gitignored).
# Soft dependency: missing file uses auto defaults.

# auto | 1 | 0
FM_CBM_ENABLED=auto

# SQLite graph store (shared by all crewmates on this host)
# FM_CBM_CACHE_DIR=/root/var/cbm-cache

# Resource caps for indexing/query on small VPS hosts
FM_CBM_MEM_BUDGET_MB=1024
FM_CBM_WORKERS=2

# Optional absolute path to binary if not on PATH
# FM_CBM_BIN=/root/.local/bin/codebase-memory-mcp
