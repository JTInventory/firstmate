#!/usr/bin/env bash
# Attach the JT Understand Anything reference packet to Firstmate task briefs.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FM_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
FM_HOME="${FM_HOME:-$FM_ROOT}"
REFRESH_BIN="${FM_UNDERSTAND_REFRESH_BIN:-$FM_HOME/bin/fm-understand-jt-refresh}"
STATE_DIR="$FM_HOME/state"
SUMMARY_PATH="$STATE_DIR/jt-understand-graph.summary.json"
REFERENCE_PATH="$STATE_DIR/jt-understand-graph.reference.md"
MARKER_START="<!-- firstmate:jt-understand-anything:start -->"
AUTO_REFRESH="${FM_UNDERSTAND_JT_AUTO_REFRESH:-1}"

usage() {
  cat <<'USAGE'
usage: fm-understand-jt-reference [brief-block|append-brief-if-jt <brief> [project] [task-id]|should-attach <brief> [project] [task-id]]
USAGE
}

is_jt_context() {
  local brief="${1:-}" project="${2:-}" task_id="${3:-}" hay=""
  case "$(printf '%s' "$task_id" | tr '[:upper:]' '[:lower:]')" in
    jt-*) return 0 ;;
  esac
  hay="$project $task_id $brief"
  if [ -f "$brief" ]; then
    hay="$hay $(head -120 "$brief" 2>/dev/null || true)"
  fi
  if printf '%s' "$hay" | tr '[:upper:]' '[:lower:]' | grep -Eq 'jt-control-room|jt control room|refresh:doctor|4187|donnees|jt automation'; then
    return 0
  fi
  return 1
}

summary_fresh() {
  local node_bin
  node_bin="$(command -v node || true)"
  if [ -n "$node_bin" ]; then
    "$node_bin" -e 'let s="";process.stdin.on("data",d=>s+=d);process.stdin.on("end",()=>{try{const j=JSON.parse(s);process.stdout.write(j.fresh?"true":"false")}catch{process.stdout.write("false")}})' < "$SUMMARY_PATH" 2>/dev/null || echo false
  else
    grep -q '"fresh": true' "$SUMMARY_PATH" && echo true || echo false
  fi
}

ensure_reference() {
  [ -x "$REFRESH_BIN" ] || return 1
  "$REFRESH_BIN" --status >/dev/null || true
  if [ "$AUTO_REFRESH" = "1" ] && [ -f "$SUMMARY_PATH" ]; then
    if [ "$(summary_fresh)" != "true" ]; then
      "$REFRESH_BIN" --refresh >/dev/null || true
    fi
  fi
  "$REFRESH_BIN" --reference >/dev/null || true
  [ -f "$REFERENCE_PATH" ]
}

brief_block() {
  ensure_reference || {
    cat <<'EOF'
<!-- firstmate:jt-understand-anything:start -->

# JT Control Room structure reference

Understand Anything reference is unavailable. Continue from direct code and runtime inspection.

<!-- firstmate:jt-understand-anything:end -->
EOF
    return 0
  }
  cat "$REFERENCE_PATH"
}

append_brief_if_jt() {
  local brief="${1:-}" project="${2:-}" task_id="${3:-}"
  [ -n "$brief" ] && [ -f "$brief" ] || return 0
  is_jt_context "$brief" "$project" "$task_id" || return 0
  grep -Fq "$MARKER_START" "$brief" && return 0
  {
    printf '\n'
    brief_block
  } >> "$brief"
}

case "${1:-brief-block}" in
  brief-block|packet)
    brief_block
    ;;
  append-brief-if-jt)
    shift
    append_brief_if_jt "$@"
    ;;
  should-attach)
    shift
    is_jt_context "$@" && exit 0 || exit 1
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
